# ===== Phase 1 設定 (バックエンド呼び出し) =====

# バックエンドの URL (デフォルト: http://localhost:3001)
BACKEND_URL=http://localhost:3001

# 一貫性テスト (AI-C-001〜003) の連続呼び出し回数 (デフォルト 10)
# CI 等で短縮したい場合は 3 等に設定可能。
# CONSISTENCY_RUNS=10

# 一貫性テスト中の呼び出し間 sleep (秒、レート制限対策、デフォルト 1.0)
# CONSISTENCY_SLEEP_SEC=1


# ===== Phase 2 設定 (LLM-as-a-judge) =====

# 判定 AI モデル (デフォルト: claude-sonnet-4-6)
# 万一動作しない場合は他のモデル ID に切り替え可能。
# LLM_JUDGE_MODEL=claude-sonnet-4-6

# スコア閾値 (この値以上で合格、デフォルト 3)
# LLM_JUDGE_PASS_THRESHOLD=3

# 判定 AI の temperature (デフォルト 0、判定の安定性を最大化)
# LLM_JUDGE_TEMPERATURE=0

# 判定 AI の max_tokens (デフォルト 500)
# LLM_JUDGE_MAX_TOKENS=500

# Anthropic API キー (Phase 2 で判定 AI を呼び出すために必須)
# tests/ai-quality/.env に書くか、backend/.env から自動的に流用される。
# ANTHROPIC_API_KEY=your_api_key_here
