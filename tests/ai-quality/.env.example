# バックエンドの URL (デフォルト: http://localhost:3001)
# テストはこの URL の /api/recommend を呼び出す。
# 直接 Anthropic API を叩かないため、ANTHROPIC_API_KEY はここでは不要 (backend/.env で管理)。
BACKEND_URL=http://localhost:3001

# 一貫性テスト (AI-C-001〜003) の連続呼び出し回数
# デフォルト 10 (テスト設計書 4.2 準拠)。
# CI 等で短縮したい場合は 3 等に設定可能 (ローカル開発用)。
# CONSISTENCY_RUNS=10

# 一貫性テスト中の呼び出し間 sleep (秒、レート制限対策)
# CONSISTENCY_SLEEP_SEC=1
